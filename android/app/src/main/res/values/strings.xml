<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- App name displayed in the launcher -->
    <string name="app_name">GeoGive</string>

    <!--
        Asset statements URL.
        This points to the Digital Asset Links JSON file
        hosted on your domain. The TWA library fetches this
        to verify domain ownership.
    -->
    <string name="asset_statements">
        [{
            \"relation\": [\"delegate_permission/common.handle_all_urls\"],
            \"target\": {
                \"namespace\": \"web\",
                \"site\": \"https://gandzekas.github.io/geogive/\"
            }
        }]
    </string>

    <!-- Fallback URL if local asset is not available -->
    <string name="fallback_url">https://gandzekas.github.io/geogive/</string>

    <!-- Custom Tabs package preference (Chrome) -->
    <string name="custom_tabs_provider">com.android.chrome</string>
</resources>
